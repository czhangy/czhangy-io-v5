{
    "name": "czhangy-io",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "npx eslint",
        "format": "prettier --write .",
        "init": "npm install && npm run gen:setup && npm run prisma:generate",
        "gen:setup": "pip install -r requirements.txt",
        "gen:component": "PYTHONPATH=src python3 ./src/lib/scripts/generators/generate_component.py",
        "gen:class": "PYTHONPATH=src python3 ./src/lib/scripts/generators/generate_class.py",
        "gen:icon": "PYTHONPATH=src python3 ./src/lib/scripts/generators/generate_icon.py",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,scss,css}": [
            "prettier --write"
        ],
        "*.scss": [
            "stylelint --fix"
        ]
    },
    "dependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "axios": "^1.18.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "next": "16.2.9",
        "prettier": "^3.8.4",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "sass": "^1.101.0",
        "stylelint": "^17.13.0",
        "stylelint-order": "^8.1.1"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.9",
        "typescript": "^5"
    }
}
