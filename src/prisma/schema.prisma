generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    ADMIN
    USER
}

model User {
    id             String   @id @default(cuid())
    hashedPassword String
    role           Role     @default(USER)
    createdAt      DateTime @default(now())
}
