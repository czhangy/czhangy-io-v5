generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    ADMIN
    USER
}

model Users {
    id             String   @id @default(cuid())
    hashedPassword String
    role           Role     @default(USER)
    createdAt      DateTime @default(now())
}

model Highlights {
    key       String   @id
    value     String
    updatedAt DateTime @updatedAt
}

model Content {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    mediaType String
    poster    String
    genres    String[]
    addedAt   DateTime @default(now())
}

model Books {
    id      Int      @id @default(autoincrement())
    name    String
    author  String
    cover   String
    genres  String[]
    addedAt DateTime @default(now())

    @@unique([name, author])
}

model Achievements {
    id          Int      @id @default(autoincrement())
    tier        Int      @default(1)
    name        String   @unique
    category    String
    description String
    date        String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model Moves {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    type      String
    count     Int      @default(0)
    createdAt DateTime @default(now())
}

model Games {
    id     Int    @id @default(autoincrement())
    name   String @unique
    genre  String
    icon   String
    rating Float
}
