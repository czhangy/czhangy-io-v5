generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    ADMIN
    USER
}

model User {
    id             String   @id @default(cuid())
    hashedPassword String
    role           Role     @default(USER)
    createdAt      DateTime @default(now())
}

model StatusItem {
    key       String   @id
    value     String
    updatedAt DateTime @updatedAt
}

model Achievement {
    id          Int      @id @default(autoincrement())
    tier        Int      @default(1)
    name        String
    category    String
    description String
    date        String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}
