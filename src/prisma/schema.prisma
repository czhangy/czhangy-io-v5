generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    ADMIN
    USER
}

model Users {
    id             String   @id @default(cuid())
    hashedPassword String
    role           Role     @default(USER)
    createdAt      DateTime @default(now()) @db.Timestamptz(3)
}

model Highlights {
    key       String   @id
    value     String
    updatedAt DateTime @updatedAt
}

model Content {
    id        Int      @id @default(autoincrement())
    name      String
    mediaType String
    poster    String
    genres    String[]
    addedAt   DateTime @default(now()) @db.Timestamptz(3)

    @@unique([name, poster])
}

model Books {
    id      Int      @id @default(autoincrement())
    name    String
    author  String
    cover   String
    genres  String[]
    addedAt DateTime @default(now()) @db.Timestamptz(3)

    @@unique([name, author])
}

model Achievements {
    id          Int      @id @default(autoincrement())
    tier        Int      @default(1)
    name        String   @unique
    category    String
    description String
    date        String?
    createdAt   DateTime @default(now()) @db.Timestamptz(3)
}

model Moves {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    type      String
    tutorial  String
    count     Int      @default(0)
    createdAt DateTime @default(now()) @db.Timestamptz(3)
}

model Games {
    id     Int    @id @default(autoincrement())
    name   String @unique
    genre  String
    icon   String
    rating Float
}

model Jobs {
    id        Int      @id @default(autoincrement())
    company   String
    title     String
    startDate String
    endDate   String?
    logo      String
    createdAt DateTime @default(now()) @db.Timestamptz(3)

    @@unique([company, startDate])
}

model Logs {
    id        Int      @id @default(autoincrement())
    slug      String   @unique
    title     String   @unique
    tags      String[]
    body      String
    createdAt DateTime @default(now()) @db.Timestamptz(3)
    updatedAt DateTime @updatedAt
}

// Singleton row holding the in-progress "new log" draft, so autosave
// survives across devices/sessions for the single admin user.
model LogDraft {
    id        String   @id @default("draft")
    title     String   @default("")
    tags      String[] @default([])
    body      String   @default("")
    updatedAt DateTime @updatedAt
}
