generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    ADMIN
    USER
}

model User {
    id             String   @id @default(cuid())
    hashedPassword String
    role           Role     @default(USER)
    createdAt      DateTime @default(now())
}

model StatusItem {
    key       String   @id
    value     String
    updatedAt DateTime @updatedAt
}

model WatchedMedia {
    id        Int      @id @default(autoincrement())
    name      String
    tmdbId    Int      @unique
    mediaType String
    poster    String
    genres    String[]
    addedAt   DateTime @default(now())
}

model ReadMedia {
    id        Int      @id @default(autoincrement())
    name      String
    author    String
    bookId    String   @unique
    cover     String
    genres    String[]
    addedAt   DateTime @default(now())
}

model Achievement {
    id          Int      @id @default(autoincrement())
    tier        Int      @default(1)
    name        String   @unique
    category    String
    description String
    date        String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model CardistryMove {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    type      String
    count     Int      @default(0)
    createdAt DateTime @default(now())
}

model Game {
    id     Int    @id @default(autoincrement())
    name   String @unique
    genre  String
    icon   String
    rating Float
}
